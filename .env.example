# =============================================================================
# Auto-generated values (setup.sh 每次自動偵測，請勿手動修改)
# =============================================================================
USER_NAME=
USER_GROUP=
USER_UID=1000
USER_GID=1000
HARDWARE=x86_64
DOCKER_HUB_USER=
GPU_ENABLED=false
IMAGE_NAME=ros_noetic

# =============================================================================
# 需要手動設定的值（第一次執行 setup.sh 時會引導填寫）
# =============================================================================

# 掛載至容器內的工作區路徑（絕對路徑）
WS_PATH=../workspace

# =============================================================================
# 可選：覆蓋 Dockerfile 預設值
# =============================================================================
# ROS_DISTRO=noetic
# ROS_TAG=ros-base
# UBUNTU_CODENAME=focal
